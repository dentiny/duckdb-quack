# name: test/sql/rpc.test
# description: test rpc extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require rpc

statement ok con1
select start_rpc_server('/tmp/duckdb-rpc-socket');

sleep 100 millisecond

query I con2
from call_rpc_server('/tmp/duckdb-rpc-socket', 'select 42')
----
42

query I con2
select max(range) from call_rpc_server('/tmp/duckdb-rpc-socket', 'from range(100000)')
----
99999



