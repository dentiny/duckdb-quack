# name: test/sql/attach_ctas.test
# description: test CREATE TABLE AS over rpc attach
# group: [sql]

include test/template/quack_setup.test_template

statement ok
attach {server} as rpc (token 'asdf')

statement ok
create table rpc.t as select range a from range(10);

query I
from rpc.t select count(a);
----
10

statement ok
drop table rpc.t;

statement ok con2
detach rpc;

include test/template/quack_teardown.test_template
