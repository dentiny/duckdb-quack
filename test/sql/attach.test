# name: test/sql/attach.test
# description: test rpc extension
# group: [sql]

include test/template/quack_setup.test_template

statement ok quack_db:quack_server_con
create schema moo;

statement ok quack_db:quack_server_con
create table fuu as values(42, 43);

statement ok quack_db:quack_server_con
create table moo.fuu2 as values(44, 45);

query II
from quack_query({server}, 'select 42, 43', token='asdf')
----
42	43

# we can attach with a straight token
statement ok
attach {server} as rpc2 (token 'asdf')

statement ok
detach rpc2;

statement ok
create secret (type quack, token 'asdf')

statement ok
attach {server} as rpc

query I
from rpc.query('BEGIN; select 42; COMMIT;')
----
42

query II
from rpc.fuu;
----
42	43

query I
from rpc.query('select 42');
----
42

query I
from rpc.main.fuu select col1 where col0=42 ;
----
43

query II
from rpc.main.fuu where col0=43;
----

statement error
from rpc.yyyy
----
Table with name yyyy does not exist

statement error
from rpc.xxx.yyy;
----
schema "xxx" does not exist

