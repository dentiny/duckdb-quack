statement ok
begin transaction


statement ok
create table rpc.fuu2(i integer);


statement ok
from rpc.fuu2;

statement ok
commit

statement ok
from rpc.fuu2;


statement ok
drop table rpc.fuu2;


statement ok
begin transaction

statement ok
create table rpc.fuu3(i integer);

statement ok
insert into rpc.fuu3 from range(10000);

query I
from rpc.fuu3 select count(i);
----
10000

statement ok
rollback

statement error
from rpc.fuu3;
----
not exist


statement ok
detach rpc;

statement error
detach rpc;
----
database not found

include test/template/quack_teardown.test_template

statement error
attach {server} as rpc
----
